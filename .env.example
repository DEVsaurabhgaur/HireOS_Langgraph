# HireOS — Environment Variables
# Copy this to .env and fill in your actual values.
# NEVER commit the real .env file — it is in .gitignore.

# ── Required (Google Gemini AI) ──────────────────────────────────────────────
# Free key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-gemini-api-key-here

# ── Required (Razorpay Payments) ─────────────────────────────────────────────
# Find in: https://dashboard.razorpay.com → Settings → API Keys
# KEY_ID   = public key (starts with rzp_live_ or rzp_test_)
# KEY_SECRET is NOT used in this app (client-side checkout only)
RAZORPAY_KEY_ID=rzp_live_your-key-id-here

# ── Add both of these to Vercel Environment Variables ────────────────────────
# Vercel dashboard → Your Project → Settings → Environment Variables
